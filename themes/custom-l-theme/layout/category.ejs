<section class="category-page">
  <div class="container">
    <header class="page-header">
      <h1>文章分类</h1>
    </header>

    <div class="category-content">
      <% if (site.categories.length > 0) { %>
        <div class="category-grid">
          <% site.categories.forEach(cat => { %>
            <div class="category-card">
              <h3 class="category-name">
                <a href="<%= url_for(cat.path) %>"><%= cat.name %></a>
              </h3>
              <span class="category-count"><%= cat.posts.length %> 篇文章</span>
              <ul class="category-posts">
                <% cat.posts.slice(0, 5).forEach(post => { %>
                  <li><a href="<%= url_for(post.path) %>"><%= post.title %></a></li>
                <% }) %>
                <% if (cat.posts.length > 5) { %>
                  <li><a href="<%= url_for(cat.path) %>" class="view-all">查看全部 →</a></li>
                <% } %>
              </ul>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <p>暂无分类</p>
        </div>
      <% } %>
    </div>
  </div>
</section>